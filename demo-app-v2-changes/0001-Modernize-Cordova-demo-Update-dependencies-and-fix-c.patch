@@ -7,6 +7,7 @@ var audioContext, micGainNode, filterNode, // Web Audio API
     captureCfg = null, // Capture configuration object
     audioDataQueue = [], // Audio queue
     concatenateMaxChunks = 10, // How many data buffer chunks should be joined before playing them
+    maxQueueSize = 100, // Maximum queue size to prevent memory leak (100 chunks max)
 
     timerGetNextAudio, timerInterVal, // Info/Debug timers
     totalReceivedData = 0, // Info/Debug received data
@@ -22,7 +23,15 @@ function onAudioInputCapture(evt) {
     try {
         if (evt && evt.data) {
             totalReceivedData += evt.data.length;
-            audioDataQueue.push(evt.data); // Push the data to the audio queue (array)
+
+            // Prevent memory leak by limiting queue size
+            if (audioDataQueue.length < maxQueueSize) {
+                audioDataQueue.push(evt.data); // Push the data to the audio queue (array)
+            } else {
+                console.warn("Audio queue full, dropping oldest chunk");
+                audioDataQueue.shift(); // Remove oldest
+                audioDataQueue.push(evt.data); // Add newest
+            }
         }
     }
     catch (ex) {
@@ -37,7 +46,7 @@ function onAudioInputCapture(evt) {
  * @param error
  */
 function onAudioInputError(error) {
-    alert("onAudioInputError event recieved: " + JSON.stringify(error));
+    alert("onAudioInputError event received: " + JSON.stringify(error));
 }
 
 
