+import { useState, useEffect, useRef } from 'react';
+
+interface EventsDemoProps {
+  onBack: () => void;
+}
+
+function EventsDemo({ onBack }: EventsDemoProps) {
+  const [isCapturing, setIsCapturing] = useState(false);
+  const [status, setStatus] = useState('Ready to start');
+  const [audioLevel, setAudioLevel] = useState(0);
+
+  const handleStart = async () => {
+    try {
+      setStatus('Starting capture...');
+      setIsCapturing(true);
+      setStatus('Capturing audio!');
+      // AudioInput integration would go here
+    } catch (error) {
+      setStatus(`Error: ${error}`);
+      setIsCapturing(false);
+    }
+  };
+
+  const handleStop = () => {
+    setStatus('Stopped');
+    setIsCapturing(false);
+    setAudioLevel(0);
+  };
+
+  return (
+    <div className="demo">
+      <button className="back-btn" onClick={onBack}>← Back</button>
+      
+      <h1>Events Demo</h1>
+      <p>Capture raw audio data and play it back using Web Audio API</p>
+
+      <div className="status">{status}</div>
+
+      {isCapturing && (
+        <div className="audio-meter">
+          <div className="audio-bar" style={{ width: `${audioLevel}%` }} />
+        </div>
+      )}
+
+      <div className="controls">
+        <button 
+          onClick={handleStart} 
+          disabled={isCapturing}
+          className="btn-start"
+        >
+          Start Capture
+        </button>
+        <button 
+          onClick={handleStop} 
+          disabled={!isCapturing}
+          className="btn-stop"
+        >
+          Stop Capture
+        </button>
+      </div>
+
+      <div className="info">
+        <h3>How it Works</h3>
+        <ul>
+          <li>Captures raw PCM audio data from microphone</li>
+          <li>Processes data using Web Audio API</li>
+          <li>Plays back audio with minimal latency</li>
+        </ul>
+      </div>
+    </div>
+  );
+}
+
+export default EventsDemo;
