+import WebAudioDemo from './components/WebAudioDemo';
+import WavDemo from './components/WavDemo';
+import FileDemo from './components/FileDemo';
+
+type DemoType = 'home' | 'events' | 'webaudio' | 'wav' | 'file';
+
+function App() {
+  const [currentDemo, setCurrentDemo] = useState<DemoType>('home');
+
+  const renderDemo = () => {
+    switch (currentDemo) {
+      case 'events':
+        return <EventsDemo onBack={() => setCurrentDemo('home')} />;
+      case 'webaudio':
+        return <WebAudioDemo onBack={() => setCurrentDemo('home')} />;
+      case 'wav':
+        return <WavDemo onBack={() => setCurrentDemo('home')} />;
+      case 'file':
+        return <FileDemo onBack={() => setCurrentDemo('home')} />;
+      default:
+        return (
+          <div className="home">
+            <h1>AudioInput Plugin v2.0</h1>
+            <p className="subtitle">Capacitor Demo - React + TypeScript</p>
+
+            <div className="demo-grid">
+              <button
+                className="demo-card"
+                onClick={() => setCurrentDemo('events')}
+              >
+                <div className="icon">📡</div>
+                <h2>Events Demo</h2>
+                <p>Capture raw audio data and play it back using Web Audio API</p>
+              </button>
+
+              <button
+                className="demo-card"
+                onClick={() => setCurrentDemo('webaudio')}
+              >
+                <div className="icon">🎵</div>
+                <h2>Web Audio Demo</h2>
+                <p>Stream audio directly to speakers with AudioNode integration</p>
+              </button>
+
+              <button
+                className="demo-card"
+                onClick={() => setCurrentDemo('wav')}
+              >
+                <div className="icon">💾</div>
+                <h2>WAV Demo</h2>
+                <p>Encode captured audio to WAV format</p>
+              </button>
+
+              <button
+                className="demo-card"
+                onClick={() => setCurrentDemo('file')}
+              >
+                <div className="icon">📁</div>
+                <h2>File Demo</h2>
+                <p>Record audio and save to device storage</p>
+              </button>
+            </div>
+
+            <div className="features">
+              <h3>Features</h3>
+              <ul>
+                <li>Real-time microphone capture</li>
+                <li>Multiple audio sources (Default, Camcorder, Unprocessed, etc.)</li>
+                <li>Web Audio API integration</li>
+                <li>File recording with WAV encoding</li>
+                <li>TypeScript type safety</li>
+                <li>Modern React hooks</li>
+              </ul>
+            </div>
+          </div>
+        );
+    }
+  };
+
+  return (
+    <div className="app">
+      {renderDemo()}
+    </div>
+  );
+}
+
+export default App;
